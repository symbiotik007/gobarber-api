# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3333
APP_URL=https://your-api.up.railway.app
APP_SECRET=change_me_to_a_long_random_string_min_32_chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-client.vercel.app,https://your-panel.vercel.app

# ── Client URL (used in booking confirmation email links) ─────────────────────
CLIENT_URL=https://your-client.vercel.app

# ── Database (PostgreSQL — Neon or Railway Postgres) ─────────────────────────
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# ── MongoDB (optional — notifications queue) ──────────────────────────────────
MONGO_URL=

# ── Redis (optional — bee-queue) ─────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Email (Mailtrap sandbox or production SMTP) ───────────────────────────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass

# ── Sentry (optional — error tracking) ───────────────────────────────────────
SENTRY_DSN=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
